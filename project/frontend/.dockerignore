# =============================================================================
# Frontend Docker Ignore
# Prevents unnecessary files from being copied into the Docker image
# =============================================================================

# Node modules (will be installed in container)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Build output (will be generated in container)
dist/
build/

# IDE / Editor
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Testing
coverage/
*.lcov

# Development files
.env
.env.*
!.env.example
.env.local
.env.development
.env.test
.env.production

# Local dev server
*.local

# Logs
*.log
logs/

# Documentation
*.md

# Git
.git/
.gitignore

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# CI/CD
.github/
.gitlab-ci.yml

# Misc
*.drawio
*.plantuml

# Cypress / E2E tests
cypress/
cypress.config.*

# Storybook
.storybook/
*.stories.*
