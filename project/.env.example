# =============================================================================
# PPT Master - Environment Variables Example
# Copy this file to .env and fill in your actual values
# =============================================================================

# =============================================================================
# Database (PostgreSQL)
# =============================================================================

# PostgreSQL connection URL (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://pptmaster:pptmaster@db:5432/pptmaster

# Individual connection parameters (used by docker-compose)
POSTGRES_DB=pptmaster
POSTGRES_USER=pptmaster
POSTGRES_PASSWORD=ChangeThisStrongPassword123!

# =============================================================================
# Redis
# =============================================================================

# Redis connection URL
REDIS_URL=redis://redis:6379/0

# Celery broker and result backend (usually same as REDIS_URL with different DB)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# =============================================================================
# MinIO (Object Storage)
# =============================================================================

# MinIO server endpoint (use 'minio:9000' for Docker, 'localhost:9000' for local dev)
MINIO_ENDPOINT=minio:9000

# MinIO credentials (MUST be changed in production!)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=ChangeThisMinioPassword456!

# MinIO bucket name for storing PPT resources
MINIO_BUCKET=pptmaster

# MinIO access credentials (if different from root)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=ChangeThisMinioPassword456!

# Use HTTPS for MinIO connections (set to true in production with SSL)
MINIO_SECURE=false

# =============================================================================
# LLM (OpenAI / Anthropic)
# =============================================================================

# OpenAI API Key (required for GPT model support)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key (required for Claude model support)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Default LLM provider (openai | anthropic)
DEFAULT_LLM_PROVIDER=openai

# Default LLM model
# OpenAI options: gpt-4o, gpt-4o-mini, gpt-4-turbo
# Anthropic options: claude-3-5-sonnet-latest, claude-3-opus-latest
DEFAULT_LLM_MODEL=gpt-4o

# =============================================================================
# PPT Master Skill
# =============================================================================

# Path to the ppt-master skill directory inside the container
PPT_MASTER_SKILL_DIR=/app/ppt-master/skills/ppt-master

# Host path to the ppt-master skill (mounted as volume in docker-compose)
# Set this to the absolute path on your host machine
PPT_MASTER_SKILL_HOST_PATH=/path/to/your/ppt-master

# =============================================================================
# Application Settings
# =============================================================================

# Debug mode (true/false) - NEVER enable in production
DEBUG=false

# Log level: debug, info, warning, error, critical
LOG_LEVEL=info

# Log format: json (production), text (development)
LOG_FORMAT=json

# CORS allowed origins (comma-separated)
# Use "*" for development only
CORS_ORIGINS=http://localhost,http://localhost:5173

# Secret key for JWT/session signing (generate a strong random key!)
# Use: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-this-in-production

# =============================================================================
# Celery Worker Settings
# =============================================================================

# Number of Celery worker replicas (for docker-compose scale)
CELERY_WORKER_REPLICAS=1

# Worker-specific settings
CELERY_WORKER_MAX_TASKS_PER_CHILD=50

# Celery beat scheduler
CELERY_BEAT_ENABLED=true

# =============================================================================
# Port Mappings (for docker-compose)
# =============================================================================

# Frontend (nginx)
FRONTEND_PORT=80

# Frontend dev server (Vite)
FRONTEND_DEV_PORT=5173

# Backend API
BACKEND_PORT=8000

# PostgreSQL
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# MinIO
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# pgAdmin (development tool)
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@pptmaster.local
PGADMIN_PASSWORD=admin

# Redis Insight (development tool)
REDIS_INSIGHT_PORT=5540

# =============================================================================
# Security Headers
# =============================================================================

# Content Security Policy (optional)
# CSP_HEADER=default-src 'self'

# =============================================================================
# Feature Flags
# =============================================================================

# Enable/disable source file conversion caching
ENABLE_CONVERSION_CACHE=true

# Enable/disable SVG quality checking
ENABLE_SVG_QUALITY_CHECK=true

# Enable/disable image generation via AI
ENABLE_AI_IMAGE_GENERATION=true

# Enable/disable image search from web
ENABLE_WEB_IMAGE_SEARCH=true

# =============================================================================
# Monitoring & Observability (Optional)
# =============================================================================

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://your-sentry-dsn

# Prometheus metrics endpoint (optional)
# METRICS_ENABLED=true
# METRICS_PORT=9090

# =============================================================================
# Performance Tuning
# =============================================================================

# Maximum upload file size (MB)
MAX_UPLOAD_SIZE_MB=100

# Request timeout (seconds)
REQUEST_TIMEOUT=120

# Database connection pool size
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# =============================================================================
# Docker Resource Limits (for docker-compose deploy section)
# =============================================================================

# These are set in docker-compose.yml deploy.resources section
# Adjust based on your server resources:
#
# DB_LIMITS_CPUS=2.0
# DB_LIMITS_MEMORY=1G
# REDIS_LIMITS_CPUS=1.0
# REDIS_LIMITS_MEMORY=256M
# BACKEND_LIMITS_CPUS=2.0
# BACKEND_LIMITS_MEMORY=1G
# CELERY_LIMITS_CPUS=2.0
# CELERY_LIMITS_MEMORY=2G
# FRONTEND_LIMITS_CPUS=1.0
# FRONTEND_LIMITS_MEMORY=256M
